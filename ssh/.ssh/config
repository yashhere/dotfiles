# CVE-2016-0777
UseRoaming no

Host *
  ServerAliveInterval 60
  PermitLocalCommand yes

Host github.com
  IdentityFile ~/.ssh/id_rsa.personal
  IdentitiesOnly yes

Host gitlab.com
  IdentityFile ~/.ssh/id_rsa.personal
  IdentitiesOnly yes

Host bitbucket-*.com
  PubkeyAcceptedKeyTypes +ssh-rsa
  IdentitiesOnly yes
